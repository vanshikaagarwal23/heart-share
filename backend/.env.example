# Copy this file to .env and fill in real values.
# Never commit the actual .env file — it is already in .gitignore.

# MongoDB connection string
MONGO_URI=mongodb://localhost:27017/mern-auth

# Secret used to sign JWTs. MUST be a long, random, unguessable string in
# every environment (local, staging, production) and MUST be unique per
# environment. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_a_long_random_value

# How long issued tokens stay valid
JWT_EXPIRE=7d

# Port the API server listens on
PORT=5000

# Origin of the deployed frontend — required so CORS allows it.
# Without this set, the API will only accept requests from
# http://localhost:5173 / http://localhost:5174 (dev defaults).
CLIENT_URL=http://localhost:5173

# development | production — controls morgan request logging
NODE_ENV=development
